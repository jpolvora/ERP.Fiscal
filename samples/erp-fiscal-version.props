<Project>
  <!--
    Importe no consumidor (ex.: Directory.Build.props ou common.props):
      <Import Project="erp-fiscal-version.props" Condition="Exists('erp-fiscal-version.props')" />

    CI: pin versão fixa (reprodutível).
    Dev: use 0.1.* para última versão de main.
  -->
  <PropertyGroup>
    <ErpFiscalPackageVersion>0.1.17</ErpFiscalPackageVersion>
    <!-- Exemplo pinado para CI: <ErpFiscalPackageVersion>0.1.42</ErpFiscalPackageVersion> -->
  </PropertyGroup>
</Project>
